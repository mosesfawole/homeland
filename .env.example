# Database
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=verify-full
# Optional: path to a CA certificate file used to verify the DB connection.
PG_SSL_CERT_PATH=
# Dev-only fallback when you are behind a proxy that injects self-signed certs.
PG_SSL_NO_VERIFY=false

# Auth
NEXTAUTH_SECRET=replace-with-strong-secret
NEXTAUTH_URL=http://localhost:3000
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# AI (Anthropic)
ANTHROPIC_API_KEY=replace-with-anthropic-key

# Cloudinary
CLOUDINARY_CLOUD_NAME=replace-with-cloud-name
CLOUDINARY_API_KEY=replace-with-api-key
CLOUDINARY_API_SECRET=replace-with-api-secret

# Resend
RESEND_API_KEY=replace-with-resend-key
RESEND_FROM_EMAIL="Homeland <onboarding@resend.dev>"

# DNS fix for Node on some networks
NODE_OPTIONS=--dns-result-order=ipv4first
