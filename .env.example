# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=replace-with-service-role-key

# Auth
NEXTAUTH_SECRET=replace-with-strong-secret
NEXTAUTH_URL=http://localhost:3000
NEXT_PUBLIC_SITE_URL=http://localhost:3000
AUTH_DEV_BYPASS_EMAIL_VERIFICATION=0
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-me
ADMIN_NAME=Admin

# AI (Gemini)
AI_PROVIDER=gemini
GEMINI_API_KEY=replace-with-gemini-key
GEMINI_MODEL=gemini-2.5-flash

# AI (Anthropic)
ANTHROPIC_API_KEY=replace-with-anthropic-key

# Upstash (rate limiting)
UPSTASH_REDIS_REST_URL=https://your-upstash-url.upstash.io
UPSTASH_REDIS_REST_TOKEN=replace-with-upstash-token

# Cloudinary
CLOUDINARY_CLOUD_NAME=replace-with-cloud-name
CLOUDINARY_API_KEY=replace-with-api-key
CLOUDINARY_API_SECRET=replace-with-api-secret

# Resend
RESEND_API_KEY=replace-with-resend-key
RESEND_FROM_EMAIL="Homeland <onboarding@resend.dev>"

# DNS fix for Node on some networks
NODE_OPTIONS=--dns-result-order=ipv4first
